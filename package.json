    "@prisma/client": "^6.0.0",
    "@sparticuz/chromium": "^149.0.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "cuid": "^3.0.0",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "next": "^16.1.0",
    "nodemailer": "^9.0.3",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.0.0",
    "puppeteer-core": "^25.3.0",
