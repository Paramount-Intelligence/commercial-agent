    "validator:test": "tsx scripts/test-validator.ts",
    "pricing:test": "tsx scripts/test-pricing.ts",
    "contacts:test": "tsx scripts/test-contacts.ts",
    "agent:test": "tsx --env-file=.env.local scripts/test-agent-turn.ts",
    "ids:audit": "tsx --env-file=.env.local scripts/audit-case-ids.ts",
    "ids:remap:dry": "tsx --env-file=.env.local scripts/remap-case-ids.ts --dry-run",
    "ids:remap": "tsx --env-file=.env.local scripts/remap-case-ids.ts",
