    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
