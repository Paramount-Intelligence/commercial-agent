# Database — required
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# AI — required for chat/retrieval
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# AI — optional overrides
ANTHROPIC_VOICE_MODEL="claude-haiku-4-5"
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"

# Voice — required when voice mode is enabled
ELEVENLABS_API_KEY="..."

# Authentication and encrypted organization credentials — required
# AUTH_COOKIE_SECRET must be at least 32 characters.
AUTH_COOKIE_SECRET="replace-with-at-least-32-random-characters"
# Generate with: npx tsx scripts/generate-org-key.ts
ORG_SECRET_KEY="replace-with-a-base64-encoded-32-byte-key"

# Durable generated assets — required on Vercel for one-pager persistence
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Transactional email — required for email verification
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_..."
SMTP_FROM="Paramount Intelligence Adviser <adviser@example.com>"

# Local document-generation overrides — optional; do not set on Vercel
PUPPETEER_EXECUTABLE_PATH=""
CHROME_PATH=""
